function bDone(){
  const rep=bRep();
  const rp=document.getElementById('rp');
  if(rp)rp.textContent=rep;
  document.getElementById('ep_email_input').addEventListener('input',function(){sv('ep_email',this.value);});
  document.getElementById('bmail').onclick=()=>{
    const btnEl=document.getElementById('bmail');
    const email=document.getElementById('ep_email_input').value||'';
    const child=(gv('child_forename')+' '+(gv('child_surname')||'')).trim();
    const subject=encodeURIComponent('EP Teacher Questionnaire (EYFS) — '+child);
    navigator.clipboard.writeText(rep).then(()=>{
      const link=document.createElement('a');
      link.href='mailto:'+encodeURIComponent(email)+'?subject='+subject;
      link.click();
      btnEl.textContent='Report copied — paste into the email body (Ctrl+V / Cmd+V)';
      btnEl.style.background='#27734a';
      setTimeout(()=>{btnEl.textContent='📧 Open Pre-filled Email to EP';btnEl.style.background='';},6000);
    }).catch(()=>{
      const link=document.createElement('a');
      link.href='mailto:'+encodeURIComponent(email)+'?subject='+subject;
      link.click();
      alert('Your email has opened. Please use the Copy Report button below and paste the report into the email body.');
    });
  };
  document.getElementById('bcp').onclick=()=>{
    navigator.clipboard.writeText(rep).then(()=>{
      document.getElementById('bcp').textContent='Copied!';
      setTimeout(()=>{document.getElementById('bcp').textContent='📋 Copy Report to Clipboard';},3000);
    }).catch(()=>{if(rp){const r=document.createRange();r.selectNode(rp);window.getSelection().removeAllRanges();window.getSelection().addRange(r);}alert('Long-press on the text above and choose Copy.');});
  };
  document.getElementById('bbk').onclick=()=>{ST.phase='form';ST.si=SECS.length-1;render();};
}

