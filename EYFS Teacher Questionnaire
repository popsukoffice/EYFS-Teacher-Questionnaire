  <div class="attlabel">${pct>0?pct+'% attendance':''} ${pct>0&&pct<80?'&#9888;&#65039; Severely absent':pct>0&&pct<90?'&#9888;&#65039; Persistently absent':pct>=90?'&#10003; Broadly on track':''}</div>
