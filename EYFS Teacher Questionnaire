function rTick(sec,title,icon,desc){
  const subs=TDATA[sec];
  const sl=title.split(':')[0];
  let html=`<div class="sh"><span class="sbadge">Section ${sl}</span><h2>${icon} ${title.split(': ')[1]||title}</h2><p>${desc}</p></div>
  <div class="sinote">&#10003; <strong>Left side (teal)</strong> = things the child does or is beginning to do in your setting &nbsp;|&nbsp; &#9888; <strong>Right side (red)</strong> = things the child finds difficult or cannot yet do in your setting. Base your answers on what you directly observe.</div>`;
  subs.forEach(sub=>{
    html+=`<div class="tsec">
    <div class="tttl">${sub.t}</div>
    <div class="tchdr"><span class="shdr">&#10003; Strengths — Doing Well in Setting</span><span class="dhdr">&#9888; Difficulties — Not Yet / Struggling in Setting</span></div>
    <div class="tbody">
      <div class="tcol sc">${sub.ps.map(p=>`<label class="ti"><input type="checkbox" id="c_${p.id}_s"${gv(p.id+'_s')?' checked':''}><span>${p.s}</span></label>`).join('')}</div>
      <div class="tcol dc">${sub.ps.map(p=>`<div>
        <label class="ti"><input type="checkbox" id="c_${p.id}_d"${gv(p.id+'_d')?' checked':''}><span>${p.d}</span></label>
        ${rDex(p.id)}
      </div>`).join('')}</div>
    </div>
    <div class="tnotes"><label>Additional notes for this section (optional):</label>
    <textarea id="fi_${sub.n}" placeholder="Anything else to add about this area — include specific examples where possible...">${esc(gv(sub.n))}</textarea></div>
    </div>`;
  });
  html+=rOuts(sec);
  return html;
}

function rDex(pid){
  const hkey=pid+'_d';
  const hints=DH[hkey]||['e.g., describe specifically how this difficulty presents in your setting day-to-day','e.g., describe strategies currently in place and their impact'];
  const open=gv(pid+'_d');
  return`<div class="dex${open?' open':''}" id="dx_${pid}">
  <div class="egrid">
    <div><span class="dlbl">How does this present in your setting?</span>
    <textarea id="fi_${pid}_imp" placeholder="${hints[0]}">${esc(gv(pid+'_imp'))}</textarea></div>
    <div><span class="dlbl">What strategies/support are currently in place?</span>
    <textarea id="fi_${pid}_sup" placeholder="${hints[1]}">${esc(gv(pid+'_sup'))}</textarea></div>
  </div></div>`;
}

function rOuts(sec){
  const outs=OUTS[sec];if(!outs)return'';
  return`<div class="obox"><h3>&#127919; Desired Outcomes (Setting View)</h3>
  <p>After 12 months of support, what would you like this child to be able to do in the setting? These help the EP set goals in their report. Complete the most relevant ones.</p>
  ${outs.map(o=>`<div class="oi"><label>${o.l}</label><textarea id="fi_${o.id}" placeholder="${o.ph}">${esc(gv(o.id))}</textarea></div>`).join('')}
  </div>`;
}

function rCV(){
