let ST={phase:'intro',si:0,d:{}};

function lST(){try{const s=localStorage.getItem(SK);if(s){const p=JSON.parse(s);ST.d=p.d||{};ST.si=p.si||0;return true;}}catch(e){}return false;}
function sST(){try{localStorage.setItem(SK,JSON.stringify({d:ST.d,si:ST.si,sv:new Date().toISOString()}));}catch(e){}}
function hSaved(){try{const s=JSON.parse(localStorage.getItem(SK));return s&&s.d&&Object.keys(s.d).length>0;}catch(e){return false;}}
function sName(){try{const s=JSON.parse(localStorage.getItem(SK));return(s&&s.d&&s.d.child_forename)||'';}catch(e){return'';}}
function sTime(){try{const s=JSON.parse(localStorage.getItem(SK));if(s&&s.sv)return new Date(s.sv).toLocaleString('en-GB',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});}catch(e){}return'';}

let _st=null;
function dbSave(){clearTimeout(_st);_st=setTimeout(()=>{sST();fSave();},700);}
function fSave(){const b=document.getElementById('svb');if(!b)return;b.classList.remove('hidden');clearTimeout(b._t);b._t=setTimeout(()=>b.classList.add('hidden'),2000);}

function sv(k,v){ST.d[k]=v;dbSave();}
function gv(k,def=''){return ST.d[k]!==undefined?ST.d[k]:def;}
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function render(){
  const a=document.getElementById('app');
  if(ST.phase==='intro'){a.innerHTML=rIntro();bIntro();return;}
  if(ST.phase==='done'){a.innerHTML=rDone();bDone();return;}
  a.innerHTML=rForm();bForm();window.scrollTo(0,0);
}

function rIntro(){
  const hs=hSaved(),nm=sName(),tm=sTime();
  return`<div class="iw"><div class="ic">
  <h2>EP Teacher Questionnaire</h2>
  <div class="st">Early Years (EYFS) &amp; Early Developmental Needs &nbsp;|&nbsp; Teacher &amp; Key Worker Version &nbsp;|&nbsp; &copy; 2026 POPS</div>
  <p style="font-size:14px;color:#4a5568;margin-bottom:4px">This questionnaire helps the Educational Psychologist gather information from the setting before an EP assessment. It is designed for children in <strong>Early Years settings</strong>, or children in KS1/KS2 who are <strong>functioning at an Early Years level</strong>. Please be as specific and evidence-based as possible.</p>
  <div class="infobox"><strong>How to use this questionnaire</strong>
  <p>Work through each section using the tabs along the top. Your answers are <strong>saved automatically on this device</strong> as you type — you do not need to finish in one sitting.</p>
  <p>To return later, open <strong>this same page in the same browser on the same device</strong> and tap <strong>"Continue where I left off"</strong>.</p>
  <p>When finished, tap <strong>"Finish — Send to EP"</strong> at the end. You will be able to copy the completed report and open a pre-filled email to send directly to the EP service.</p></div>
  ${hs?`<div class="resbox"><strong>Saved progress found</strong><p>${nm?`Child: <strong>${nm}</strong><br>`:''}Last saved: ${tm}</p></div>
  <button class="btn btp" id="br">Continue where I left off &rarr;</button>
  <button class="btn bts" id="bn2">Start fresh (clears all saved answers)</button>`
  :`<button class="btn btp" id="bs">Begin Questionnaire &rarr;</button>`}
  </div></div>`;
}
function bIntro(){
  const r=document.getElementById('br'),n=document.getElementById('bn2'),s=document.getElementById('bs');
  if(r)r.onclick=()=>{lST();ST.phase='form';render();};
  if(n)n.onclick=()=>{if(confirm('Erase all saved answers and start again?')){localStorage.removeItem(SK);ST={phase:'form',si:0,d:{}};render();}};
  if(s)s.onclick=()=>{ST.phase='form';render();};
}

function rForm(){
  const sec=SECS[ST.si];
  const pct=Math.round(ST.si/(SECS.length-1)*100);
  return`<header class="hdr">
  <div><h1>EP Questionnaire — Teacher/Setting Version</h1><div class="sub">EYFS &amp; Early Needs &middot; &copy; 2026 POPS</div></div>
  <span class="pct">${pct}%</span>
  </header>
  <div id="svb" class="svb hidden">&#10003; Progress saved automatically</div>
  <nav class="snav">${SECS.map((s,i)=>`<button class="npill${i===ST.si?' act':i<ST.si?' vis':''}" data-i="${i}">${s.i} ${s.t}</button>`).join('')}</nav>
  <div class="fw" id="fw">
    ${rSec(sec)}
    <div class="nbs">
      ${ST.si>0?'<button class="btn bts" id="bb">&larr; Back</button>':''}
      ${ST.si<SECS.length-1?'<button class="btn btp" id="bn">Save &amp; Continue &rarr;</button>':'<button class="btn btf" id="bf">Finish &mdash; Send to EP &#10003;</button>'}
    </div>
  </div>`;
}

function rSec(sec){
  if(sec.id==='det')return rDet();
  if(sec.id==='bg')return rBg();
  if(sec.id==='att')return rAtt();
  if(sec.id==='sup')return rSup();
  if(sec.id==='pri')return rPri();
  if(sec.id==='phy')return rTick('phy','A: Physical & Sensory','🏃','Tick all items that apply based on your observations in the setting. When you tick a <span style="color:var(--rose);font-weight:700">difficulty</span>, two boxes will appear asking about impact in setting and current strategies used.');
  if(sec.id==='com')return rTick('com','B: Communication & Interaction','💬','Tick all that apply. This covers all forms of communication observed in the setting — verbal and non-verbal. When you tick a <span style="color:var(--rose);font-weight:700">difficulty</span>, two boxes will appear.');
  if(sec.id==='sem')return rTick('sem','C: Emotional & Social Development','❤️','Tick all that apply based on observations in the setting. When you tick a <span style="color:var(--rose);font-weight:700">difficulty</span>, two boxes will appear.');
  if(sec.id==='cog')return rTick('cog','D: Learning, Play & Early Development','🧩','Tick all that apply to what you observe in the setting. When you tick a <span style="color:var(--rose);font-weight:700">difficulty</span>, two boxes will appear.');
  if(sec.id==='cv')return rCV();
  if(sec.id==='tv')return rTV();
  return'';
}

