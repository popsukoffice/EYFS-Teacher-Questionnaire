function bForm(){
  document.querySelectorAll('.npill').forEach(p=>p.addEventListener('click',()=>{cAll();ST.si=parseInt(p.dataset.i);render();}));
  const bb=document.getElementById('bb'),bn=document.getElementById('bn'),bf=document.getElementById('bf');
  if(bb)bb.onclick=()=>{cAll();ST.si--;render();};
  if(bn)bn.onclick=()=>{cAll();ST.si++;render();};
  if(bf)bf.onclick=()=>{cAll();ST.phase='done';render();};

  document.querySelectorAll('input[type=checkbox]').forEach(cb=>{
    cb.addEventListener('change',()=>{
      if(cb.id.startsWith('c_')&&cb.id.endsWith('_d')){
        const base=cb.id.slice(2,-2);
        const ex=document.getElementById('dx_'+base);
        if(ex)ex.classList.toggle('open',cb.checked);
      }
      const co=cb.closest('.co');if(co)co.classList.toggle('sel',cb.checked);
      cAll();
    });
  });

  document.querySelectorAll('input[type=radio]').forEach(r=>{
    r.addEventListener('change',()=>{
      document.querySelectorAll(`input[name="${r.name}"]`).forEach(x=>{const p=x.closest('.ro');if(p)p.classList.toggle('sel',x.checked);});
      if(r.name==='bg_ong'){const w=document.getElementById('bg_ong_d');if(w)w.style.display=r.value==='Yes'?'':'none';}
      if(r.name==='bg_sc'){const w=document.getElementById('bg_sc_d');if(w)w.style.display=r.value==='Yes'?'':'none';}
      if(r.name==='bg_adv'){const w=document.getElementById('bg_adv_d');if(w)w.style.display=r.value==='Yes'?'':'none';}
      if(r.name==='iep'){const w=document.getElementById('iep_d');if(w)w.style.display=r.value==='Yes'?'':'none';}
      cAll();
    });
  });

  document.querySelectorAll('input[type=number]').forEach(el=>{
    el.addEventListener('input',()=>{
      if(el.id==='fi_att_pct'||el.id==='fi_att_possible'||el.id==='fi_att_attended'){
        cAll();
        const pos=parseFloat(document.getElementById('fi_att_possible')?.value)||0;
        const att=parseFloat(document.getElementById('fi_att_attended')?.value)||0;
        if(pos>0&&att>0&&el.id!=='fi_att_pct'){
          const pct=Math.round(att/pos*100);
          const pctInput=document.getElementById('fi_att_pct');
          if(pctInput){pctInput.value=pct;sv('att_pct',pct);}
        }
      }
    });
  });

  document.querySelectorAll('input,textarea,select').forEach(el=>{el.addEventListener('input',cAll);el.addEventListener('change',cAll);});
}

function cAll(){
  document.querySelectorAll('[id^="fi_"]').forEach(el=>{sv(el.id.slice(3),el.value);});
  document.querySelectorAll('input[type=checkbox]').forEach(cb=>{if(cb.id)sv(cb.id.startsWith('c_')?cb.id.slice(2):cb.id,cb.checked);});
  document.querySelectorAll('input[type=radio]:checked').forEach(r=>{if(r.name)sv(r.name,r.value);});
  document.querySelectorAll('select').forEach(s=>{if(s.id){const k=s.id.startsWith('fi_')?s.id.slice(3):s.id.startsWith('s_')?s.id.slice(2):s.id;sv(k,s.value);}});
  sST();
}

lST();render();
</script>
