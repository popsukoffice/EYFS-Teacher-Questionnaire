  const barW=Math.min(pct,100);
  return`<div class="sh"><span class="sbadge">3. Attendance</span><h2>📅 Attendance Record</h2><p>Attendance patterns are important context for the EP. Please complete as accurately as possible based on your records.</p></div>
  <div class="teach-note">📊 <strong>Why attendance matters:</strong> Persistent absence (below 90%) significantly affects learning and development. Patterns of absence (e.g., specific days, following weekends, illness-related) help the EP understand context and impact. Below 80% is classed as severe absence.</div>
  <div class="card"><div class="fr3">
  <div><label>Sessions/days possible this year</label><input type="number" id="fi_att_possible" value="${esc(gv('att_possible'))}" placeholder="e.g. 160" min="0"></div>
  <div><label>Sessions/days attended this year</label><input type="number" id="fi_att_attended" value="${esc(gv('att_attended'))}" placeholder="e.g. 130" min="0"></div>
  <div><label>Attendance % (this year)</label><input type="number" id="fi_att_pct" value="${esc(gv('att_pct'))}" placeholder="e.g. 81" min="0" max="100"></div></div>
